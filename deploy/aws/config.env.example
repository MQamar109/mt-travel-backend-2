# AWS deployment configuration
# Copy to config.env and fill in values before running ./deploy.sh

AWS_REGION=us-east-1
PROJECT_NAME=mt-travel

# GitHub repos (public clone URLs used on EC2)
BACKEND_REPO=https://github.com/MQamar109/mt-travel-backend-2.git

# EC2 settings (free tier)
EC2_INSTANCE_TYPE=t3.micro
EC2_KEY_NAME=mt-travel-deploy-key

# Optional overrides (leave empty to auto-generate)
# SECRET_KEY=
# DB_PASSWORD=

# Email (optional — needed for invoice/report emails)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
